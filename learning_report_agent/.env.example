# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Power BI Integration
POWERBI_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POWERBI_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POWERBI_CLIENT_SECRET=your-client-secret-value
POWERBI_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SMTP Email Delivery (leave blank to use dry-run mode — PDF saved to disk)
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# Outlook/Office365: smtp.office365.com port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=Learning Report Agent <your-email@gmail.com>

# App Settings
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# Paths (auto-set by config.py, override if needed)
# DATA_DIR=./data
# DB_PATH=./data/learning_agent.db
